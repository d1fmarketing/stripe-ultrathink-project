{
  "name": "stripe-chargeback-autopilot",
  "version": "1.0.0",
  "description": "Stripe-only chargeback automation with CE3.0 and ML prediction",
  "scripts": {
    "build": "tsc && for file in src/handlers/*.ts; do esbuild \"$file\" --bundle --platform=node --target=node20 --format=cjs --outfile=\"dist/handlers/$(basename \"${file%.ts}.js\")\"; done",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "deploy": "serverless deploy --stage prod",
    "deploy:dev": "serverless deploy --stage dev",
    "remove": "serverless remove",
    "seo:generate": "tsx growth/seo-seeder.ts",
    "growth:seo": "npm run seo:generate",
    "growth:metrics": "echo 'Metrics dashboard: https://console.aws.amazon.com/cloudwatch'",
    "ai:test": "tsx tests/test-ai.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.864.0",
    "@aws-sdk/client-dynamodb": "^3.868.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-sagemaker-runtime": "^3.864.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/client-ses": "^3.600.0",
    "@aws-sdk/client-sfn": "^3.600.0",
    "@aws-sdk/client-ssm": "^3.864.0",
    "@aws-sdk/lib-dynamodb": "^3.864.0",
    "@langchain/openai": "^0.6.7",
    "@pinecone-database/pinecone": "^6.1.2",
    "@redis/json": "^5.8.1",
    "@redis/search": "^5.8.1",
    "@redis/time-series": "^5.8.1",
    "axios": "^1.11.0",
    "bull": "^4.16.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^13.4.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.30",
    "node-fetch": "^3.3.2",
    "openai": "^5.12.2",
    "redis": "^5.8.1",
    "stripe": "^18.4.0",
    "pino": "^9.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.11",
    "esbuild": "^0.20.2",
    "jest": "^29.7.0",
    "netlify-cli": "^23.1.4",
    "serverless": "^3.39.0",
    "serverless-esbuild": "^1.55.1",
    "serverless-step-functions": "^3.23.3",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
